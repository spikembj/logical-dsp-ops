# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local-only reference data (sample CSVs/PDFs we design parsers against — never commit real ops data)
/_reference/

# supabase CLI scratch
supabase/.temp/
supabase/.branches/

# editor / OS
.idea/
.vscode/
.claude/settings.local.json
*.swp
*.swo
*~

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
