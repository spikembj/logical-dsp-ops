# Copy to .env.local and fill in. .env.local is gitignored.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_. Used only in trusted server
# contexts (route handlers, server actions). Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Default timezone for week-ending boundaries and other ops display.
NEXT_PUBLIC_DEFAULT_TZ=America/Denver
